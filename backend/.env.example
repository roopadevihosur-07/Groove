VAPI_SCHEDULER_AGENT_ID=your_scheduler_agent_id
VAPI_REMINDER_AGENT_ID=your_reminder_agent_id
VAPI_EDUCATOR_AGENT_ID=your_educator_agent_id

# ─── TINYFISH ──────────────────────────────────────────────────────────────────
TINYFISH_API_KEY=your_tinyfish_api_key_here

# ─── NEXLA ─────────────────────────────────────────────────────────────────────
